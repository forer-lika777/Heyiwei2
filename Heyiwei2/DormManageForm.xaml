<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Heyiwei2.DormManageForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Heyiwei2"
    xmlns:models="using:Heyiwei2.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid DataContext="{Binding}">
        <Rectangle Fill="{ThemeResource SmokeFillColorDefaultBrush}"/>
        <Grid Margin="100, 80, 100, 80">
            <Rectangle Fill="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
                       RadiusX="10"
                       RadiusY="10"/> <!--Rectangle： 矩形图案，不能包含控件-->
            <ScrollView>
                <StackPanel Padding="22, 22, 22, 80"
                            Spacing="20"> <!--排列方式-->
                    <TextBlock Text="查看宿舍信息"
                               FontSize="25"/>
                    <StackPanel Orientation="Horizontal"
                                Spacing="50">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding Info.ToString, Mode=OneWay}"
                                       FontSize="15"
                                       VerticalAlignment="Center"/> <!--Mode: 数据绑定类型（oneway：单向、 twoway：双向、 onetime: 一次性） 默认onetime-->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="加入时间："/>
                                <TextBlock Text="{Binding Info.StartDateYear}"/>
                                <TextBlock Text="年"/>
                                <TextBlock Text="{Binding Info.StartDateMonth}"/>
                                <TextBlock Text="月"/>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="EditDormButton"
                                Click="EditDormButton_Click">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <SymbolIcon Symbol="Edit"/> <!--调用系统图案-->
                                <TextBlock Text="编辑"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel Spacing="20">
                        <TextBlock Text="学生列表"/>
                        <ListView ItemsSource="{Binding Students}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Student">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="30">
                                        <TextBlock Text="{x:Bind Name}"/>
                                        <TextBlock Text="{x:Bind StudentId}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                    <StackPanel Spacing="20">
                        <TextBlock Text="所有用水信息"/>
                        <ListView Height="200"
                                  ItemsSource="{Binding Records}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:WaterRecord">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal">
                                            <TextBlock Text="{x:Bind Year}"/>
                                            <TextBlock Text="年"/>
                                            <TextBlock Text="{x:Bind Month}"/>
                                            <TextBlock Text="月"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal">
                                            <TextBlock Text="用水量："/>
                                            <TextBlock Text="{x:Bind Usage}"/>
                                            <TextBlock Text="吨"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal">
                                            <TextBlock Text="计费："/>
                                            <TextBlock Text="{x:Bind Cost}"/>
                                            <TextBlock Text="元"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </StackPanel>
            </ScrollView>
            <Button x:Name="CloseButton"
                    Style="{StaticResource SubtleButtonStyle}"
                    CornerRadius="8"
                    Padding="0"
                    Width="40" 
                    Height="40"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Click="CloseButton_Click">
                <Grid HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch" 
                      Width="Auto" 
                      Height="Auto">
                    <SymbolIcon Symbol="Cancel" 
                                HorizontalAlignment="Center"/>
                </Grid>
            </Button>
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Bottom"
                        Padding="35"
                        Spacing="20">
                <!--<Button x:Name="SaveButton"
                        MinWidth="200"
                        Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <SymbolIcon Symbol="Save"/>
                        <TextBlock Text="保存"/>
                    </StackPanel>
                </Button>-->
                <Button x:Name="AddRecord"
                        MinWidth="130"
                        Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6">
                        <SymbolIcon Symbol="Add"/>
                        <TextBlock Text="添加学生"/>
                    </StackPanel>
                </Button>
                <Button x:Name="AddRecordButton"
                        MinWidth="130"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="AddRecordButton_Click">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6">
                        <SymbolIcon Symbol="Add"/>
                        <TextBlock Text="添加用水记录"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
