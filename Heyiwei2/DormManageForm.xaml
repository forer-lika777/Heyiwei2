<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Heyiwei2.DormManageForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Heyiwei2"
    xmlns:models="using:Heyiwei2.Models"
    xmlns:converters="using:Heyiwei2.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:HasPaidToStringConverter x:Key="HasPaidToStringConverter"/>
    </UserControl.Resources>

    <Grid DataContext="{Binding}">
        <Rectangle Fill="{ThemeResource SmokeFillColorDefaultBrush}"/>
        <Grid Margin="100, 80, 100, 80">
            <Rectangle Fill="{ThemeResource SolidBackgroundFillColorTertiaryBrush}" RadiusX="10" RadiusY="10"/>
            <!--Rectangle： 矩形图案，不能包含控件-->
            <ScrollView>
                <StackPanel Padding="22, 22, 22, 80" Spacing="20">
                    <!--排列方式-->
                    <TextBlock Text="查看宿舍信息" FontSize="25"/>
                    <StackPanel Orientation="Horizontal" Spacing="50">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding Info.ToString}" FontSize="15" VerticalAlignment="Center"/>
                            <!--Mode: 数据绑定类型（oneway：单向、 twoway：双向、 onetime: 一次性） 默认onetime-->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="加入时间："/>
                                <TextBlock Text="{Binding Info.StartDateYear}"/>
                                <TextBlock Text="年"/>
                                <TextBlock Text="{Binding Info.StartDateMonth}"/>
                                <TextBlock Text="月"/>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="EditDormButton" Click="EditDormButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Edit"/>
                                <!--调用系统图案-->
                                <TextBlock Text="编辑"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel Spacing="20">
                        <TextBlock Text="学生列表"/>
                        <ScrollView ContentOrientation="Horizontal">
                            <ListView Height="200" ItemsSource="{Binding Students, Mode=OneWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Student">
                                        <Grid Height="50" MinWidth="650">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Padding="10">
                                                <TextBlock Text="学号："/>
                                                <TextBlock Text="{x:Bind StudentId, Mode=OneWay}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        VerticalAlignment="Center" HorizontalAlignment="Left" Padding="10">
                                                <TextBlock Text="姓名："/>
                                                <TextBlock Text="{x:Bind Name, Mode=OneWay}"/>
                                            </StackPanel>
                                            <Button x:Name="EditStudentButton" Grid.Column="2" 
                                                    VerticalAlignment="Center" Click="EditStudentButton_Click">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <SymbolIcon Symbol="Edit"/>
                                                    <!--调用系统图案-->
                                                    <TextBlock Text="编辑"/>
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="DeleteStudentButton" Grid.Column="3"
                                                    VerticalAlignment="Center" Click="DeleteStudentButton_Click">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <SymbolIcon Symbol="Delete"/>
                                                    <!--调用系统图案-->
                                                    <TextBlock Text="删除"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </ScrollView>
                        
                    </StackPanel>
                    <StackPanel Spacing="20">
                        <TextBlock Text="所有用水信息"/>
                        <ScrollView ContentOrientation="Horizontal">
                            <ListView Height="200" ItemsSource="{Binding Records, Mode=OneWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:WaterRecord">
                                        <Grid Height="50" MinWidth="650">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                        VerticalAlignment="Center" HorizontalAlignment="Left" Padding="10">
                                                <TextBlock Text="{x:Bind Year, Mode=OneWay}"/>
                                                <TextBlock Text="年"/>
                                                <TextBlock Text="{x:Bind Month, Mode=OneWay}"/>
                                                <TextBlock Text="月"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        VerticalAlignment="Center" HorizontalAlignment="Left" Padding="10">
                                                <TextBlock Text="用水量："/>
                                                <TextBlock Text="{x:Bind Usage, Mode=OneWay}"/>
                                                <TextBlock Text="吨"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center" HorizontalAlignment="Left" Padding="10">
                                                <TextBlock Text="计费："/>
                                                <TextBlock Text="{x:Bind Cost, Mode=OneWay}"/>
                                                <TextBlock Text="元"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="3"
                                                       VerticalAlignment="Center" HorizontalAlignment="Left" Padding="10"
                                                       Text="{x:Bind HasPaid, Mode=OneWay, Converter={StaticResource HasPaidToStringConverter}}"/>
                                            <Button x:Name="EditRecordButton" Grid.Column="4"
                                                    VerticalAlignment="Center" Click="EditRecordButton_Click">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <SymbolIcon Symbol="Edit"/>
                                                    <!--调用系统图案-->
                                                    <TextBlock Text="编辑"/>
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="DeleteRecordButton" Grid.Column="5"
                                                    VerticalAlignment="Center" Click="DeleteRecordButton_Click">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <SymbolIcon Symbol="Delete"/>
                                                    <!--调用系统图案-->
                                                    <TextBlock Text="删除"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </ScrollView>
                    </StackPanel>
                </StackPanel>
            </ScrollView>
            <Button x:Name="CloseButton" Style="{StaticResource SubtleButtonStyle}"
                    CornerRadius="8" Padding="0" Width="40"  Height="40"
                    VerticalAlignment="Top" HorizontalAlignment="Right" Click="CloseButton_Click">
                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                      Width="Auto" Height="Auto">
                    <SymbolIcon Symbol="Cancel" HorizontalAlignment="Center"/>
                </Grid>
            </Button>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"
                        Padding="35" Spacing="20">
                <Button x:Name="AddStudentButton" MinWidth="130"
                        Style="{StaticResource AccentButtonStyle}" Click="AddStudentButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Add"/>
                        <TextBlock Text="添加学生"/>
                    </StackPanel>
                </Button>
                <Button x:Name="AddRecordButton" MinWidth="130"
                        Style="{StaticResource AccentButtonStyle}" Click="AddRecordButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Add"/>
                        <TextBlock Text="添加用水记录"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>