<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Heyiwei2.DormManageForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Heyiwei2"
    xmlns:models="using:Heyiwei2.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid DataContext="{x:Bind Dorm}">
        <Rectangle Fill="{ThemeResource SmokeFillColorDefaultBrush}"/>
        <Grid Margin="100, 80, 100, 80">
            <Rectangle Fill="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
                       RadiusX="10"
                       RadiusY="10"/>
            <StackPanel Padding="32"
                        Spacing="24">
                <TextBlock Text="查看宿舍信息"
                           FontWeight="SemiBold"
                           FontSize="35"/>
                <StackPanel Orientation="Horizontal"
                            Spacing="50">
                    <TextBlock Text="{Binding Info.ToString}"
                               FontSize="17"
                               VerticalAlignment="Center"/>
                    <Button x:Name="EditDormButton">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <SymbolIcon Symbol="Edit"/>
                            <TextBlock Text="编辑信息"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Spacing="20">
                    <TextBlock Text="学生列表"
                               FontSize="18"/>
                    <ListView ItemsSource="{Binding Students}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Student">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="30">
                                    <TextBlock Text="{x:Bind Name}"/>
                                    <TextBlock Text="{x:Bind StudentId}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
                <StackPanel Spacing="20">
                    <TextBlock Text="所有用水信息"
                               FontSize="18"/>
                    <ListView ItemsSource="{Binding Records}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:WaterRecord">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="30">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{x:Bind Year}"/>
                                        <TextBlock Text="年"/>
                                        <TextBlock Text="{x:Bind Month}"/>
                                        <TextBlock Text="月"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

            </StackPanel>
            <Button x:Name="CloseButton" 
                    Padding="0"
                    Margin="15"
                    Width="40" 
                    Height="40"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right">
                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="Auto" Height="Auto">
                    <SymbolIcon Symbol="Cancel" HorizontalAlignment="Center"/>
                </Grid>
            </Button>
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Bottom"
                        Padding="35"
                        Spacing="20">
                <!--<Button x:Name="SaveButton"
                        MinWidth="200"
                        Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <SymbolIcon Symbol="Save"/>
                        <TextBlock Text="保存"/>
                    </StackPanel>
                </Button>-->
                <Button x:Name="AddRecord"
                        MinWidth="130"
                        Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6">
                        <SymbolIcon Symbol="Add"/>
                        <TextBlock Text="添加学生"/>
                    </StackPanel>
                </Button>
                <Button x:Name="AddRecordButton"
                        MinWidth="130"
                        Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6">
                        <SymbolIcon Symbol="Add"/>
                        <TextBlock Text="添加用水记录"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
