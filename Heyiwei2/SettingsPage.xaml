<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Heyiwei2.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Heyiwei2"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="40, 60, 20, 20" Spacing="40">
        <TextBlock Text="设置" FontSize="24" FontWeight="Bold"/>

        <ToggleSwitch x:Name="DarkModeToggle" Header="深色模式" 
                      IsOn="{x:Bind DarkModeIsOn, Mode=TwoWay}"/>
    </StackPanel>
</Page>
